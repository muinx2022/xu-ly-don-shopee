<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="XuLyDonShopee.App.Views.ImportProxyDialog"
        Width="520" Height="420"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        Title="Nhập danh sách proxy">
    <DockPanel Margin="16">
        <TextBlock DockPanel.Dock="Top" Text="Dán danh sách proxy"
                   FontSize="15" FontWeight="SemiBold" Margin="0,0,0,6" />
        <TextBlock DockPanel.Dock="Top" TextWrapping="Wrap" Foreground="#757575"
                   Margin="0,0,0,8"
                   Text="Định dạng: host:port  hoặc  host:port:user:pass — mỗi dòng một proxy." />

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8" Margin="0,10,0,0">
            <Button Content="Nhập" Click="OnImport"
                    Background="#1976D2" Foreground="White" />
            <Button Content="Hủy" Click="OnCancel" />
        </StackPanel>

        <TextBox x:Name="ProxyTextBox"
                 AcceptsReturn="True" TextWrapping="NoWrap"
                 VerticalContentAlignment="Top"
                 Watermark="1.2.3.4:8080&#x0a;1.2.3.4:8080:user:pass" />
    </DockPanel>
</Window>
