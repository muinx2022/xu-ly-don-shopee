<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:XuLyDonShopee.App.ViewModels"
             xmlns:models="using:XuLyDonShopee.Core.Models"
             xmlns:services="using:XuLyDonShopee.App.Services"
             mc:Ignorable="d" d:DesignWidth="1084" d:DesignHeight="820"
             x:Class="XuLyDonShopee.App.Views.AccountsView"
             x:DataType="vm:AccountsViewModel">

    <!-- Style CỤC BỘ cho màn này (không đụng style chung → không ảnh hưởng màn khác). -->
    <UserControl.Styles>

        <!-- Nút icon vuông của hàng thao tác nhóm (Chọn toàn bộ / Chạy / Dừng đã chọn / Dừng tất cả). -->
        <Style Selector="Button.iconAction">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{StaticResource Text5A}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.iconAction /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource CardBg}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border012}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>
        <Style Selector="Button.iconAction:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#F5F5F5" />
            <Setter Property="BorderBrush" Value="{StaticResource Border014}" />
        </Style>
        <Style Selector="Button.iconAction:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#EFEFEF" />
        </Style>
        <!-- Biến thể "Chạy đã chọn": giữ giọng accent cam như nút cũ. -->
        <Style Selector="Button.iconAction.play">
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
        </Style>
        <Style Selector="Button.iconAction.play /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource CardBg}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBorderSoft}" />
        </Style>
        <Style Selector="Button.iconAction.play:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource AccentSoft2}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBorderSoft}" />
        </Style>

        <!-- Danh sách tài khoản dạng lưới phẳng (bỏ card bo góc từng dòng). -->
        <Style Selector="ListBox.acctFlat">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="ListBox.acctFlat ListBoxItem">
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="ListBox.acctFlat ListBoxItem /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>
        <Style Selector="ListBox.acctFlat ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#0A000000" />
        </Style>
        <Style Selector="ListBox.acctFlat ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource NavActiveBg}" />
        </Style>
        <Style Selector="ListBox.acctFlat ListBoxItem:selected:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource NavActiveBg}" />
        </Style>

        <!-- Tên tài khoản trong lưới: thường xám đậm; khi phiên ĐANG MỞ (IsRunning) → xanh + SemiBold.
             Đặt màu/đậm trong style (không inline) để class .running mới override được (inline = LocalValue thắng mọi style). -->
        <Style Selector="TextBlock.acctName">
            <Setter Property="Foreground" Value="{StaticResource Text232}" />
            <Setter Property="FontWeight" Value="Medium" />
        </Style>
        <Style Selector="TextBlock.acctName.running">
            <Setter Property="Foreground" Value="#2E7D32" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <!-- Nút "Xóa" trên nền đen của panel nhật ký (tối màu cho hợp tông). -->
        <Style Selector="Button.logClear">
            <Setter Property="Height" Value="24" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#D8D8D8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.logClear /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="5" />
        </Style>
        <Style Selector="Button.logClear:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#363636" />
            <Setter Property="BorderBrush" Value="#4A4A4A" />
        </Style>
        <Style Selector="Button.logClear:pointerover">
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>

        <!-- Hàng nút thao tác của FORM chi tiết: nút ICON + NHÃN CHỮ (vd "✓ Lưu"). Chỉ override KÍCH THƯỚC
             (cao gọn 34; BỎ Width cố định để nút rộng theo nhãn; đệm ngang cho chữ thở), GIỮ nền/viền theo class
             màu đi kèm (accent = nền cam, secondary = viền, accentOutline = viền cam) nên KHÔNG đụng ContentPresenter. -->
        <Style Selector="Button.formIcon">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="FontSize" Value="13" />
        </Style>

    </UserControl.Styles>

    <!-- Bố cục: 2 cột — danh sách (trái, cao hết màn) | chi tiết + nhật ký của tài khoản đang chọn (phải). -->
    <Grid ColumnDefinitions="340,*">

            <!-- ===== Cột trái: danh sách ===== -->
            <Border Grid.Column="0"
                    BorderBrush="{StaticResource Border06}"
                    BorderThickness="0,0,1,0">
                <DockPanel Margin="24,20,20,18">

                    <TextBlock DockPanel.Dock="Top" Text="Danh sách tài khoản"
                               FontSize="19" FontWeight="Bold" LetterSpacing="-0.3"
                               Foreground="{StaticResource TextInk}"
                               Margin="0,0,0,16" />

                    <!-- Ô tìm kiếm -->
                    <Border DockPanel.Dock="Top" Classes="field" Height="36" Margin="0,0,0,14">
                        <Grid ColumnDefinitions="Auto,*">
                            <TextBlock Grid.Column="0" Text="⌕" FontSize="14"
                                       Foreground="{StaticResource Text9A}"
                                       VerticalAlignment="Center" Margin="12,0,0,0" />
                            <TextBox Grid.Column="1" Classes="bare" Margin="8,0,12,0"
                                     Text="{Binding SearchText}"
                                     Watermark="Tìm theo email / ghi chú…" />
                            <Border Classes="underline" Grid.ColumnSpan="2" />
                        </Grid>
                    </Border>

                    <!-- Hàng nút dưới -->
                    <Grid DockPanel.Dock="Bottom" ColumnDefinitions="*,Auto" Margin="0,14,0,0">
                        <Button Grid.Column="0" Classes="accent" Height="38"
                                HorizontalAlignment="Stretch"
                                Command="{Binding AddCommand}" Content="+ Thêm tài khoản" />
                        <Button Grid.Column="1" Classes="iconDanger" Margin="8,0,0,0"
                                Content="🗑" Command="{Binding DeleteCommand}"
                                IsEnabled="{Binding SelectedRow, Converter={x:Static ObjectConverters.IsNotNull}}" />
                    </Grid>

                    <!-- Hàng nút thao tác nhóm — dạng ICON (tooltip giữ nguyên nghĩa chữ cũ). -->
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6"
                                Margin="0,0,0,12">
                        <Button Classes="iconAction" Content="✓"
                                Command="{Binding SelectAllCommand}"
                                ToolTip.Tip="Chọn toàn bộ" />
                        <Button Classes="iconAction play" Content="►"
                                Command="{Binding RunSelectedCommand}"
                                ToolTip.Tip="Chạy đã chọn — Mở phiên cho các tài khoản đang tick (mở nhiều shop song song)" />
                        <Button Classes="iconAction" Content="■"
                                Command="{Binding StopSelectedCommand}"
                                ToolTip.Tip="Dừng đã chọn" />
                        <Button Classes="iconAction" Content="✕"
                                Command="{Binding StopAllCommand}"
                                ToolTip.Tip="Dừng tất cả" />
                        <!-- Kiểm tra HÀNG LOẠT: với mọi tài khoản đang tick, kiểm số đơn Chờ lấy hàng (tự mở phiên nếu chưa mở). -->
                        <Button Classes="iconAction" Content="⟳"
                                Command="{Binding CheckSelectedCommand}"
                                ToolTip.Tip="Kiểm tra đã chọn — kiểm số đơn Chờ lấy hàng của các tài khoản đang tick (tự mở phiên nếu chưa mở)" />
                        <!-- Sync HÀNG LOẠT: với mọi tài khoản đang tick, sync đơn hàng (tự mở phiên nếu chưa mở). -->
                        <Button Classes="iconAction" Content="⇊"
                                Command="{Binding SyncSelectedCommand}"
                                ToolTip.Tip="Sync đã chọn — sync đơn hàng của các tài khoản đang tick (tự mở phiên nếu chưa mở)" />
                    </StackPanel>

                    <!-- Danh sách tài khoản: mỗi dòng "[ ] Tên shop" + chấm trạng thái. -->
                    <ListBox Classes="acctFlat"
                             ItemsSource="{Binding Accounts}"
                             SelectedItem="{Binding SelectedRow}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:AccountRowViewModel">
                                <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                                    <!-- Tick chọn nhiều. CheckBox tự nuốt click nên KHÔNG đổi lựa chọn dòng
                                         (bấm vùng khác của dòng mới chọn dòng). -->
                                    <CheckBox Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0"
                                              IsChecked="{Binding IsSelected}" />
                                    <!-- Mũi tên "đang mở cửa sổ" ngay TRƯỚC tên (ẩn khi không chạy → không chiếm chỗ). -->
                                    <TextBlock Grid.Column="1" Text="►" FontSize="10" Foreground="#2E7D32"
                                               VerticalAlignment="Center" Margin="0,0,4,0"
                                               IsVisible="{Binding IsRunning}" />
                                    <!-- Tên shop: thường Text232/Medium; khi phiên ĐANG MỞ → xanh + SemiBold (class .running).
                                         Màu/đậm đặt ở style (không inline) để class .running override được. -->
                                    <TextBlock Grid.Column="2" Classes="acctName" Text="{Binding Email}"
                                               FontSize="13" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               Classes.running="{Binding IsRunning}" />
                                    <!-- Khối phải: chấm trạng thái + (khi đang chạy) chấm xanh & "Chờ lấy: N". -->
                                    <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6"
                                                VerticalAlignment="Center" Margin="8,0,0,0">
                                        <Border Width="6" Height="6" CornerRadius="3"
                                                VerticalAlignment="Center"
                                                Background="{Binding Status, Converter={StaticResource StatusColor}}" />
                                        <Border Width="6" Height="6" CornerRadius="3"
                                                VerticalAlignment="Center" Background="#2E7D32"
                                                IsVisible="{Binding IsRunning}" />
                                        <TextBlock Text="{Binding ToShipText}" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="#1565C0" VerticalAlignment="Center"
                                                   IsVisible="{Binding ToShipText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- ===== Cột phải: chi tiết (hàng trên) + nhật ký của tài khoản đang chọn (hàng dưới) ===== -->
            <Grid Grid.Column="1" RowDefinitions="*,220">

                <!-- Hàng trên: placeholder + form chi tiết (chồng nhau trong cùng ô). -->
                <Grid Grid.Row="0">

                    <!-- Placeholder khi chưa chọn -->
                    <TextBlock Text="Chọn một tài khoản hoặc bấm + Thêm tài khoản"
                               Foreground="{StaticResource Text9A}" FontSize="14"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               IsVisible="{Binding ShowPlaceholder}" />

                    <!-- Khối chi tiết -->
                    <ScrollViewer IsVisible="{Binding IsEditing}">
                        <!-- Form căng NGANG tới trần 1150 rồi CĂN GIỮA phần thừa (Stretch + MaxWidth): trên màn rộng
                             hơn Full HD không còn mảng trống lớn bên phải; hẹp hơn thì co theo khung. Bề rộng chốt
                             theo trần/khung (KHÔNG theo nội dung) → hàng nút và card KHÔNG xê dịch khi đổi tài khoản. -->
                        <StackPanel MaxWidth="1150" HorizontalAlignment="Stretch"
                                    Margin="24,16,24,20">

                        <!-- Header hàng -->
                        <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,22">
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Chi tiết tài khoản" FontSize="19" FontWeight="Bold"
                                           LetterSpacing="-0.3" Foreground="{StaticResource TextInk}" />
                                <TextBlock Text="Thông tin đăng nhập và trạng thái" FontSize="12"
                                           Foreground="{StaticResource TextMuted}" Margin="0,2,0,0" />
                            </StackPanel>

                            <!-- Badge pill trạng thái -->
                            <Border Grid.Column="1" CornerRadius="20" Padding="12,6"
                                    VerticalAlignment="Center"
                                    Background="{Binding EditStatus, Converter={StaticResource StatusPill}, ConverterParameter=bg}"
                                    BorderThickness="1"
                                    BorderBrush="{Binding EditStatus, Converter={StaticResource StatusPill}, ConverterParameter=border}">
                                <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                                    <Border Width="7" Height="7" CornerRadius="4" VerticalAlignment="Center"
                                            Background="{Binding EditStatus, Converter={StaticResource StatusColor}}" />
                                    <TextBlock Text="{Binding EditStatus, Converter={StaticResource VnEnum}}"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{Binding EditStatus, Converter={StaticResource StatusPill}, ConverterParameter=text}" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Hàng nút hành động: ICON + NHÃN CHỮ, chia 2 NHÓM rõ. Nhóm TRÁI = sửa bản ghi (Lưu/Hủy);
                             nhóm PHẢI = thao tác phiên (Kiểm tra / Sync / Dừng / Xử lý đơn / Mở trang). Khoảng '*' giữa
                             2 nhóm đẩy chúng về 2 phía. Class màu + Command + IsEnabled + tooltip GIỮ NGUYÊN. -->
                        <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,16">

                            <!-- Nhóm TRÁI: sửa bản ghi -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <Button Classes="accent formIcon" Content="✓ Lưu"
                                        Command="{Binding SaveCommand}"
                                        ToolTip.Tip="Lưu thay đổi" />
                                <Button Classes="secondary formIcon" Content="↶ Hủy"
                                        Command="{Binding CancelCommand}"
                                        ToolTip.Tip="Hủy" />
                            </StackPanel>

                            <!-- Nhóm PHẢI: thao tác phiên -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <!-- Kiểm tra: về trang chủ Seller + đọc số Chờ Lấy Hàng NGAY (không đợi 30'). Bật khi phiên đang chạy. -->
                                <Button Classes="secondary formIcon" Content="⟳ Kiểm tra"
                                        Command="{Binding CheckOrdersCommand}"
                                        IsEnabled="{Binding CanCheckOrders}"
                                        ToolTip.Tip="Kiểm tra — Về trang chủ Seller và kiểm tra số đơn Chờ Lấy Hàng ngay (không đợi chu kỳ 30')" />
                                <!-- Sync Đơn hàng: vào Quản lý đơn hàng tab Tất cả, duyệt mọi trang, lưu đơn về máy. Bật khi phiên đang chạy. -->
                                <Button Classes="secondary formIcon" Content="⇊ Sync"
                                        Command="{Binding SyncOrdersCommand}"
                                        IsEnabled="{Binding CanSyncOrders}"
                                        ToolTip.Tip="Sync Đơn hàng — vào Quản lý đơn hàng tab Tất cả, duyệt mọi trang và lưu thông tin đơn về máy" />
                                <!-- Dừng phiên của TÀI KHOẢN ĐANG CHỌN (chỉ bật khi tài khoản đó đang chạy). -->
                                <Button Classes="secondary formIcon" Content="■ Dừng"
                                        Command="{Binding StopCommand}"
                                        IsEnabled="{Binding CanStopSeller}"
                                        ToolTip.Tip="Dừng — Dừng phiên đang mở của tài khoản này (đóng cửa sổ Brave của phiên đó)" />
                                <!-- Xử lý đơn: mở Cài đặt vận chuyển → tab Địa Chỉ (kiểu người). Bật khi Chờ lấy hàng > 0. -->
                                <Button Classes="accentOutline formIcon" Content="► Xử lý đơn"
                                        Command="{Binding ProcessOrdersCommand}"
                                        IsEnabled="{Binding CanProcessOrders}"
                                        ToolTip.Tip="Xử lý đơn — Mở Cài đặt vận chuyển → tab Địa Chỉ trong phiên đang chạy (bật khi Chờ lấy hàng > 0)" />
                                <Button Classes="accentOutline formIcon" Content="↗ Mở trang"
                                        Command="{Binding OpenSellerCommand}"
                                        IsEnabled="{Binding CanOpenSeller}"
                                        ToolTip.Tip="Mở trang bán hàng — Mở Shopee Seller để đăng nhập và lưu cookie vào tài khoản này (mở nhiều tài khoản song song)" />
                            </StackPanel>

                        </Grid>

                        <!-- Thông báo trạng thái (Mở trang bán hàng / Xử lý đơn / theo dõi đơn) — ngay dưới hàng nút. -->
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="#C62828"
                                   TextWrapping="Wrap" Margin="0,0,0,16"
                                   IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                        <TextBlock Text="{Binding BusyStatus}" Foreground="#2E7D32"
                                   TextWrapping="Wrap" Margin="0,0,0,16"
                                   IsVisible="{Binding BusyStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                        <!-- Trạng thái theo dõi đơn "Chờ Lấy Hàng" (30' reload/đọc). -->
                        <TextBlock Text="{Binding OrderStatus}" Foreground="#1565C0"
                                   TextWrapping="Wrap" Margin="0,0,0,16"
                                   IsVisible="{Binding OrderStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                        <!-- 4 card dàn LƯỚI 2 CỘT (lấp bề ngang, hết cảnh neo-trái để trống mảng phải). Cột TRÁI =
                             THÔNG TIN ĐĂNG NHẬP + PROXY; cột PHẢI = COOKIE + ĐỊA CHỈ LẤY HÀNG; cột giữa 16 = khe.
                             Mỗi cột là StackPanel Spacing=12 nên card cách đều theo dọc (bỏ Margin dưới từng card). -->
                        <Grid ColumnDefinitions="*,16,*">

                            <!-- ===== Cột trái ===== -->
                            <StackPanel Grid.Column="0" Spacing="12">

                                <!-- Card: Thông tin đăng nhập (Tên đăng nhập + Mật khẩu CÙNG 1 HÀNG). -->
                                <Border Classes="card" Padding="20,16">
                                    <StackPanel Spacing="12">
                                        <TextBlock Classes="section" Text="THÔNG TIN ĐĂNG NHẬP" />

                                        <Grid ColumnDefinitions="*,14,*">
                                            <!-- Tên đăng nhập -->
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Classes="fieldLabel" Text="Tên đăng nhập" />
                                                <Border Classes="field" Height="38">
                                                    <Grid>
                                                        <TextBox Classes="bare" Margin="12,0"
                                                                 Text="{Binding EditEmail}"
                                                                 Watermark="Email hoặc tên đăng nhập" />
                                                        <Border Classes="underline" />
                                                    </Grid>
                                                </Border>
                                            </StackPanel>
                                            <!-- Mật khẩu -->
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Classes="fieldLabel" Text="Mật khẩu" />
                                                <Border Classes="field" Height="38">
                                                    <Grid ColumnDefinitions="*,Auto">
                                                        <TextBox Grid.Column="0" Classes="bare" Margin="12,0,0,0"
                                                                 Text="{Binding EditPassword}"
                                                                 PasswordChar="●"
                                                                 RevealPassword="{Binding ShowPassword}" />
                                                        <Button Grid.Column="1" Classes="ghostIcon" Margin="4,0,5,0"
                                                                Command="{Binding ToggleShowPasswordCommand}"
                                                                ToolTip.Tip="Hiện/ẩn mật khẩu">
                                                            <Panel>
                                                                <TextBlock Text="👁" FontSize="14"
                                                                           IsVisible="{Binding !ShowPassword}" />
                                                                <TextBlock Text="🙈" FontSize="14"
                                                                           IsVisible="{Binding ShowPassword}" />
                                                            </Panel>
                                                        </Button>
                                                        <Border Classes="underline" Grid.ColumnSpan="2" />
                                                    </Grid>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Card: Proxy riêng theo tài khoản (API key KiotProxy) -->
                                <Border Classes="card" Padding="20,16">
                                    <StackPanel Spacing="12">
                                        <TextBlock Classes="section" Text="PROXY" />
                                        <StackPanel>
                                            <TextBlock Classes="fieldLabel"
                                                       Text="Proxy — API key KiotProxy (mỗi tài khoản 1 proxy)" />
                                            <Border Classes="field" Height="38">
                                                <Grid>
                                                    <TextBox Classes="bare" Margin="12,0"
                                                             Text="{Binding EditProxyKey}"
                                                             Watermark="Dán API key KiotProxy cho tài khoản này (để trống = dùng cấu hình chung / IP máy)" />
                                                    <Border Classes="underline" />
                                                </Grid>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                            </StackPanel>

                            <!-- ===== Cột phải ===== -->
                            <StackPanel Grid.Column="2" Spacing="12">

                                <!-- Cookie đăng nhập: CHỈ hiện trạng thái đã có / chưa có (bỏ ô hiển thị chuỗi
                                     cookie thô để form gọn, không bị scroll). -->
                                <Border Classes="card" Padding="20,14">
                                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                        <TextBlock Classes="section" Text="COOKIE ĐĂNG NHẬP" VerticalAlignment="Center" />
                                        <TextBlock Text="✓ Đã có cookie đăng nhập" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="#2E7D32" VerticalAlignment="Center"
                                                   IsVisible="{Binding HasCookie}" />
                                        <TextBlock Text="Chưa có — mở trang bán hàng để tự lưu"
                                                   FontSize="13" Foreground="{StaticResource Text9A}"
                                                   VerticalAlignment="Center" IsVisible="{Binding !HasCookie}" />
                                    </StackPanel>
                                </Border>

                                <!-- Card: Địa chỉ lấy hàng mặc định (dùng cho xử lý đơn sau này) -->
                                <Border Classes="card" Padding="20,16">
                                    <StackPanel Spacing="12">
                                        <TextBlock Classes="section" Text="ĐỊA CHỈ LẤY HÀNG" />
                                        <StackPanel>
                                            <TextBlock Classes="fieldLabel" Text="Địa chỉ lấy hàng mặc định" />
                                            <ComboBox Classes="field" HorizontalAlignment="Stretch"
                                                      ItemsSource="{x:Static vm:AccountsViewModel.PickupAddressOptions}"
                                                      SelectedItem="{Binding EditPickupAddress}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                            </StackPanel>

                        </Grid>
                    </StackPanel>
                </ScrollViewer>
                    </Grid>

                <!-- ===== Hàng dưới của cột chi tiết: nhật ký của TÀI KHOẢN đang chọn (nền đen) ===== -->
                <Border Grid.Row="1"
                        Background="#0F1113"
                        BorderBrush="#2A2A2A" BorderThickness="0,1,0,0">
            <DockPanel Margin="12,8,12,8">

                <!-- Header: tiêu đề + nút Xóa (chỉ xóa hiển thị, không xóa file). -->
                <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                    <Grid Grid.Column="0" VerticalAlignment="Center">
                        <!-- Chưa chọn tài khoản → tiêu đề chung; đã chọn → "Nhật ký — {tên tài khoản}". -->
                        <TextBlock Text="Nhật ký hoạt động"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="#E8E8E8" VerticalAlignment="Center"
                                   IsVisible="{Binding SelectedRow, Converter={x:Static ObjectConverters.IsNull}}" />
                        <TextBlock Text="{Binding SelectedRow.Email, StringFormat='Nhật ký — {0}'}"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="#E8E8E8" VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   IsVisible="{Binding SelectedRow, Converter={x:Static ObjectConverters.IsNotNull}}" />
                    </Grid>
                    <Button Grid.Column="1" Classes="logClear"
                            Content="Xóa" Command="{Binding ClearLogCommand}"
                            ToolTip.Tip="Xóa các dòng đang hiển thị của tài khoản này (không xóa file log trên đĩa)" />
                </Grid>

                <!-- Đường dẫn file log (mờ) để biết nhật ký được ghi ở đâu — 1 dòng. -->
                <TextBlock DockPanel.Dock="Bottom" Text="{Binding LogPath}"
                           FontSize="10" Foreground="#8A8A8A"
                           TextTrimming="CharacterEllipsis" Margin="0,6,0,0" />

                <!-- Danh sách dòng log: nền đen, chữ trắng, các dòng SÁT nhau; tự cuộn xuống cuối (code-behind). -->
                <ListBox x:Name="LogList"
                         ItemsSource="{Binding FilteredLogEntries}"
                         Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.Styles>
                        <!-- Bỏ khoảng đệm/khoảng cách mặc định của ListBoxItem → dòng log sát nhau. -->
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="MinHeight" Value="0" />
                        </Style>
                        <Style Selector="ListBoxItem /template/ ContentPresenter#PART_ContentPresenter">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="MinHeight" Value="0" />
                            <Setter Property="Background" Value="Transparent" />
                        </Style>
                        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                            <Setter Property="Background" Value="#1AFFFFFF" />
                        </Style>
                        <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
                            <Setter Property="Background" Value="#22FFFFFF" />
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="services:LogEntry">
                            <TextBlock Text="{Binding Display}"
                                       FontFamily="Consolas, Menlo, monospace" FontSize="11"
                                       Foreground="#EDEDED"
                                       TextWrapping="Wrap" Margin="0" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
                </Border>
            </Grid>
        </Grid>
</UserControl>
