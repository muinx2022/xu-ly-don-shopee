<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:XuLyDonShopee.App.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1084" d:DesignHeight="820"
             x:Class="XuLyDonShopee.App.Views.AutoRunView"
             x:CompileBindings="False"
             x:DataType="vm:AutoRunViewModel">

    <ScrollViewer>
        <StackPanel MaxWidth="760" HorizontalAlignment="Left" Margin="24,24,32,40">

            <TextBlock Text="Chạy tự động" FontSize="19" FontWeight="Bold" LetterSpacing="-0.3"
                       Foreground="{StaticResource TextInk}" />
            <TextBlock Text="Mở tài khoản theo lô, tự kiểm tra/sync/xử lý đơn rồi lặp lại tới khi bấm Dừng"
                       FontSize="12" Foreground="{StaticResource TextMuted}" Margin="0,2,0,24" />

            <!-- ===== CẤU HÌNH LÔ ===== -->
            <TextBlock Classes="section" Text="CẤU HÌNH LÔ" Margin="0,0,0,12" />
            <Border Classes="card" Padding="24,22" Margin="0,0,0,24" IsEnabled="{Binding CanEditConfig}">
                <StackPanel Spacing="18">

                    <!-- N: số tài khoản mỗi lô -->
                    <StackPanel>
                        <TextBlock Classes="fieldLabel" Text="Số tài khoản mỗi lô (mở song song)" />
                        <NumericUpDown Value="{Binding BatchSize}" Minimum="1" Maximum="20" Increment="1"
                                       FormatString="0" Width="180" HorizontalAlignment="Left" />
                        <TextBlock Text="Càng nhiều thì càng mở nhiều Brave cùng lúc — nặng máy hơn."
                                   FontSize="11.5" Foreground="{StaticResource TextMuted}" Margin="0,6,0,0" />
                    </StackPanel>

                    <!-- M: nghỉ giữa các lô -->
                    <StackPanel>
                        <TextBlock Classes="fieldLabel" Text="Nghỉ giữa các lô (phút)" />
                        <NumericUpDown Value="{Binding GapMinutes}" Minimum="1" Maximum="1440" Increment="1"
                                       FormatString="0" Width="180" HorizontalAlignment="Left" />
                    </StackPanel>

                    <!-- Toggle: Tự Sync đơn hàng -->
                    <Border BorderBrush="{StaticResource Border05}" BorderThickness="0,1,0,0" Padding="0,16,0,0">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Tự Sync đơn hàng" FontSize="13.5" FontWeight="SemiBold"
                                           Foreground="{StaticResource Text252}" />
                                <TextBlock Text="Duyệt Quản lý đơn hàng, lưu đơn về máy mỗi lượt" FontSize="12"
                                           Foreground="{StaticResource TextMuted}" Margin="0,2,0,0" />
                            </StackPanel>
                            <ToggleButton Grid.Column="1" Classes="switch" VerticalAlignment="Center"
                                          IsChecked="{Binding DoSync}" />
                        </Grid>
                    </Border>

                    <!-- Toggle: Tự Xử lý đơn -->
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Tự Xử lý đơn" FontSize="13.5" FontWeight="SemiBold"
                                       Foreground="{StaticResource Text252}" />
                            <TextBlock Text="Đặt địa chỉ, chuẩn bị hàng &amp; in phiếu — GHI lên Shopee (mặc định tắt)"
                                       FontSize="12" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0" />
                        </StackPanel>
                        <ToggleButton Grid.Column="1" Classes="switch" VerticalAlignment="Center"
                                      IsChecked="{Binding DoProcess}" />
                    </Grid>

                    <!-- Ghi chú: Kiểm tra luôn chạy -->
                    <Border Background="{StaticResource InputBg}" BorderBrush="{StaticResource Border010}"
                            BorderThickness="1" CornerRadius="6" Padding="12,10">
                        <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource Text5A}"
                                   Text="Kiểm tra đơn (đọc số &quot;Chờ Lấy Hàng&quot;) LUÔN tự chạy cho mỗi tài khoản — không cần bật." />
                    </Border>

                    <!-- Lưu cấu hình -->
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Classes="accent" Height="36" Content="Lưu cấu hình"
                                Command="{Binding SaveConfigCommand}" />
                        <TextBlock Text="{Binding SavedMessage}" Foreground="#2E7D32" VerticalAlignment="Center"
                                   IsVisible="{Binding SavedMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ===== ĐIỀU KHIỂN ===== -->
            <TextBlock Classes="section" Text="ĐIỀU KHIỂN" Margin="0,0,0,12" />
            <Border Classes="card" Padding="24,22">
                <StackPanel Spacing="16">
                    <Button Classes="accent" Height="44" MinWidth="240" HorizontalAlignment="Left"
                            Content="{Binding ToggleButtonText}" Command="{Binding ToggleCommand}" />

                    <Border Background="{StaticResource InputBg}" BorderBrush="{StaticResource Border010}"
                            BorderThickness="1" CornerRadius="6" Padding="14,12">
                        <StackPanel Spacing="4">
                            <TextBlock Text="TRẠNG THÁI" FontSize="11" FontWeight="Bold" LetterSpacing="0.6"
                                       Foreground="{StaticResource TextMuted}" />
                            <TextBlock Text="{Binding StatusText}" FontSize="13.5" TextWrapping="Wrap"
                                       Foreground="{StaticResource TextInk}" />
                            <TextBlock Text="Nhật ký chi tiết theo từng tài khoản xem ở màn Tài khoản."
                                       FontSize="11.5" Foreground="{StaticResource TextMuted}" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
