<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="XuLyDonShopee.App.Views.ConfirmDialog"
        Width="440" SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Title="Xác nhận">
    <StackPanel Margin="20" Spacing="18">
        <TextBlock x:Name="MessageText" TextWrapping="Wrap" FontSize="14" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button x:Name="OkButton" Content="Đồng ý" Click="OnOk"
                    Background="#1976D2" Foreground="White" />
            <Button x:Name="CancelButton" Content="Hủy" Click="OnCancel" />
        </StackPanel>
    </StackPanel>
</Window>
