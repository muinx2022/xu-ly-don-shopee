<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:XuLyDonShopee.App.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1284" d:DesignHeight="820"
             x:Class="XuLyDonShopee.App.Views.OrdersView"
             x:CompileBindings="False"
             x:DataType="vm:OrdersViewModel">

    <!-- Nút dạng link (cột "Phiếu"): nền trong suốt, chữ cam, gạch chân khi rê chuột -->
    <UserControl.Styles>
        <Style Selector="Button.linky">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.linky /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Button.linky:pointerover">
            <Setter Property="Foreground" Value="{StaticResource AccentHoverBrush}" />
        </Style>
        <Style Selector="Button.linky:pointerover TextBlock">
            <Setter Property="TextDecorations" Value="Underline" />
        </Style>
    </UserControl.Styles>

    <DockPanel Margin="24,24,32,24">

        <!-- Tiêu đề -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
            <TextBlock Text="Đơn hàng" FontSize="19" FontWeight="Bold" LetterSpacing="-0.3"
                       Foreground="{StaticResource TextInk}" />
            <TextBlock Text="Đơn đã đồng bộ từ trang bán hàng Shopee" FontSize="12"
                       Foreground="{StaticResource TextMuted}" Margin="0,2,0,0" />
        </StackPanel>

        <!-- Thanh lọc: tài khoản · trạng thái · tìm kiếm · Làm mới · Xuất CSV -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="230,200,*,Auto,Auto" Margin="0,0,0,12">
            <!-- Lọc theo tài khoản: GÕ ĐỂ TÌM tên shop (≈100 shop, cuộn ComboBox tay rất cực).
                 AutoCompleteBox lọc gợi ý theo Email (ValueMemberBinding=Label; FilterMode=Contains — khớp
                 CHỨA, không phân biệt hoa/thường: gõ "alina" ra "alina99.store"). Chọn 1 gợi ý → SelectedAccount
                 (2 chiều) → Apply lọc như ComboBox cũ. MinimumPrefixLength=1: xóa TRẮNG ô → control tự đặt
                 SelectedItem=null → SelectedAccount=null → Apply coi accountId null = "tất cả tài khoản" (không
                 phải bảng trống). Gõ dở chưa chọn (≥1 ký tự) KHÔNG đổi SelectedItem → giữ nguyên lọc, bảng
                 không nháy. ItemTemplate hiển thị Label cho từng dòng gợi ý. -->
            <AutoCompleteBox Grid.Column="0" Classes="field" Height="38" HorizontalAlignment="Stretch"
                             ItemsSource="{Binding AccountOptions}"
                             SelectedItem="{Binding SelectedAccount, Mode=TwoWay}"
                             ValueMemberBinding="{Binding Label}"
                             FilterMode="Contains"
                             MinimumPrefixLength="1"
                             Watermark="Gõ tên shop để tìm… (trống = tất cả)">
                <AutoCompleteBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Label}" VerticalAlignment="Center" />
                    </DataTemplate>
                </AutoCompleteBox.ItemTemplate>
            </AutoCompleteBox>

            <ComboBox Grid.Column="1" Classes="field" Height="38" HorizontalAlignment="Stretch"
                      Margin="8,0,0,0"
                      ItemsSource="{Binding StatusOptions}"
                      SelectedItem="{Binding SelectedStatus}" />

            <Border Grid.Column="2" Classes="field" Height="38" Margin="8,0,0,0">
                <Grid>
                    <TextBox Classes="bare" Margin="12,0" Text="{Binding SearchText}"
                             Watermark="Tìm mã đơn / người mua / sản phẩm" />
                    <Border Classes="underline" />
                </Grid>
            </Border>

            <Button Grid.Column="3" Classes="secondary" Height="38" Content="Làm mới"
                    Margin="8,0,0,0" Command="{Binding RefreshCommand}" />
            <Button Grid.Column="4" Classes="accent" Height="38" Content="Xuất CSV"
                    Margin="8,0,0,0" Command="{Binding ExportCsvCommand}" />
        </Grid>

        <!-- Dòng tổng số + thông báo xuất -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*" Margin="0,0,0,10">
            <TextBlock Grid.Column="0" Text="{Binding TotalText}" VerticalAlignment="Center"
                       Foreground="{StaticResource Text5A}" />
            <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" HorizontalAlignment="Right"
                       VerticalAlignment="Center" Foreground="#2E7D32" TextWrapping="NoWrap"
                       IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        </Grid>

        <!-- Bảng đơn (đọc-chỉ). Bọc trong Grid 1 ô để chèn Popup "Đã copy" overlay (Popup không chiếm layout). -->
        <Grid>
        <DataGrid x:Name="OrdersGrid"
                  Classes="proxy"
                  ClipToBounds="True"
                  ItemsSource="{Binding Rows}"
                  IsReadOnly="True"
                  AutoGenerateColumns="False"
                  CanUserResizeColumns="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Tài khoản" Binding="{Binding AccountLabel}" Width="1.3*" />
                <DataGridTextColumn Header="Mã đơn" Binding="{Binding OrderSn}" Width="130" />
                <DataGridTemplateColumn Header="Phiếu" Width="90">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Classes="linky" Command="{Binding OpenSlipCommand}"
                                    ToolTip.Tip="Mở file PDF phiếu giao đã tải của đơn này">
                                <TextBlock Text="In phiếu" />
                            </Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Người mua" Binding="{Binding Buyer}" Width="1.2*" />
                <DataGridTextColumn Header="Sản phẩm" Binding="{Binding Product}" Width="2*" />
                <DataGridTextColumn Header="Tổng tiền" Binding="{Binding Total}" Width="105" />
                <DataGridTextColumn Header="Ước tính" Binding="{Binding Estimate}" Width="105" />
                <DataGridTextColumn Header="Thanh toán" Binding="{Binding Payment}" Width="1.2*" />
                <!-- Trạng thái: badge PILL nền nhạt + chữ đậm, màu theo từ khóa (OrderStatusPill).
                     Ẩn pill khi trạng thái rỗng (đơn chưa có status) → ô trống sạch, không badge xám. -->
                <DataGridTemplateColumn Header="Trạng thái" Width="140">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="10" Padding="10,3"
                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                    BorderThickness="1"
                                    Background="{Binding Status, Converter={StaticResource OrderStatusPill}, ConverterParameter=bg}"
                                    BorderBrush="{Binding Status, Converter={StaticResource OrderStatusPill}, ConverterParameter=border}"
                                    IsVisible="{Binding Status, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <TextBlock Text="{Binding Status}" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{Binding Status, Converter={StaticResource OrderStatusPill}, ConverterParameter=text}" />
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Mô tả/Lý do hủy" Binding="{Binding Note}" Width="2*" />
                <DataGridTextColumn Header="ĐVVC" Binding="{Binding Carrier}" Width="110" />
                <DataGridTextColumn Header="Mã vận đơn" Binding="{Binding Tracking}" Width="150" />
                <DataGridTextColumn Header="Sync lúc" Binding="{Binding SyncedAtDisplay}" Width="140" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Toast nhỏ "Đã copy text …": Popup neo vào ô vừa double-click, mở/ẩn (~1.2s) từ code-behind.
             Không dùng ToolTip mặc định (chỉ hiện khi hover). Nội dung do CopyToastText đặt lúc chạy. -->
        <Popup x:Name="CopyToastPopup" Placement="Top" VerticalOffset="-4"
               IsLightDismissEnabled="False" WindowManagerAddShadowHint="False">
            <Border Background="#F022272E" CornerRadius="6" Padding="10,6"
                    BoxShadow="0 2 10 0 #40000000">
                <TextBlock x:Name="CopyToastText" Foreground="White" FontSize="12"
                           TextWrapping="NoWrap" />
            </Border>
        </Popup>
        </Grid>
    </DockPanel>
</UserControl>
